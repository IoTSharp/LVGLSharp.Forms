<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<PropertyGroup>
		<PackageId>LVGLSharp.Interop</PackageId>
		<Title>LVGLSharp P/Invoke Bindings</Title>
		<Description>Auto-generated P/Invoke bindings for LVGL (via ClangSharpPInvokeGenerator). Provides low-level access to the full LVGL C API from .NET.</Description>
	</PropertyGroup>

	<!-- Depend on the native library package so the correct shared lib is
	     restored alongside the managed bindings automatically.
	     The condition limits this to CI environments (where the package
	     already exists in a feed) so that local development builds are
	     not affected before the native package is first published. -->
	<ItemGroup Condition="'$(CI)' == 'true'">
		<PackageReference Include="LVGLSharp.Native" Version="$(Version)" />
	</ItemGroup>

</Project>
